<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>📊 Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

  <style>
    body {
      font-size: 0.9rem;
      background-color: var(--bs-body-bg);
      transition: background-color 0.3s ease;
    }

    /* ===== Navbar (match upload/video) ===== */
    .navbar {
      height: 56px;
      padding: 0.5rem 1rem;
      z-index: 1050;
    }

    /* ===== Stats Cards ===== */
    .stats-card {
      border-radius: 1rem;
      padding: 1.2rem;
      text-align: center;
      background: #ffffff;
      border: 1px solid #e9ecef;
      transition: all 0.2s ease;
    }

    .stats-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .stats-card h3 {
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    /* ===== Card Styling ===== */
    .card {
      border-radius: 1rem;
      border: 1px solid #e9ecef;
    }

    .card-header {
      font-weight: 600;
    }

    .list-group-item {
      border: none;
      border-bottom: 1px solid #eee;
      font-size: 0.85rem;
    }

    /* ===== Dark Mode ===== */
    body.dark-mode {
      background-color: #0b1e35;
      color: #e0e6ed;
    }

    body.dark-mode .navbar {
      background-color: #122b45 !important;
    }

    body.dark-mode .stats-card {
      background-color: #152c48;
      border-color: #2c4566;
      color: #e0e6ed;
    }

    body.dark-mode .card {
      background-color: #152c48;
      border-color: #2c4566;
      color: #e0e6ed;
    }

    body.dark-mode .list-group-item {
      background-color: #1e3b60;
      color: #e0e6ed;
      border-color: #2c4566;
    }

    body.dark-mode .btn-light {
      background-color: #2b6cb0;
      border-color: #2b6cb0;
      color: white;
    }

    body.dark-mode .text-muted {
      color: #aebcd1 !important;
    }

    .container-dashboard {
      margin-top: 4.5rem;
    }
  </style>
</head>

<body>

<!-- ===== NAVBAR ===== -->
<nav class="navbar border-bottom fixed-top d-flex justify-content-between align-items-center px-3 bg-white">
  <span class="fw-semibold">📊 VIP Dashboard</span>

  <div class="d-flex align-items-center gap-3">
    <a href="/video" class="btn btn-sm btn-outline-secondary">📼 Video</a>
    <a href="/upload" class="btn btn-sm btn-outline-secondary">📤 Upload</a>
    <button id="toggleThemeBtn" class="btn btn-sm btn-outline-secondary">
      🌙 Dark Mode
    </button>
  </div>
</nav>

<div class="container-fluid container-dashboard p-3">

  <!-- ===== TOP STATS ===== -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="video-count">0</h3>
        <small class="text-muted">Total Video</small>
      </div>
    </div>

    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="genre-count">0</h3>
        <small class="text-muted">Genre</small>
      </div>
    </div>

    <div class="col-md-4">
      <div class="stats-card">
        <h3 id="series-count">0</h3>
        <small class="text-muted">Series</small>
      </div>
    </div>
  </div>

  <!-- ===== LATEST VIDEO ===== -->
  <div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span>🎬 Latest Video</span>
      <a href="/video" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body text-center" id="video-section">
      <p class="text-muted">Loading...</p>
    </div>
  </div>

  <div class="text-center mt-4">
    <small class="text-muted">
      Last updated: <span id="last-update">...</span>
    </small>
  </div>

</div>

<script>
  /* ===== Theme Toggle (same system as other pages) ===== */
  const themeBtn = document.getElementById('toggleThemeBtn');
  const body = document.body;

  if (localStorage.getItem('theme') === 'dark') {
    body.classList.add('dark-mode');
    themeBtn.textContent = '☀️ Light Mode';
  }

  themeBtn.addEventListener('click', () => {
    body.classList.toggle('dark-mode');
    const isDark = body.classList.contains('dark-mode');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    themeBtn.textContent = isDark ? '☀️ Light Mode' : '🌙 Dark Mode';
  });

  /* ===== Dashboard Auto Refresh ===== */
  async function refreshDashboard() {
    try {
      const res = await fetch('/api/dashboard');
      const data = await res.json();

      const video = data.video;
      const videoContainer = document.getElementById('video-section');

      videoContainer.innerHTML = video
        ? `
          <img src="/${video.thumbnail}" 
               class="img-fluid rounded mb-3 shadow-sm"
               style="max-height:180px;">
          <ul class="list-group text-start small">
            <li class="list-group-item"><strong>🎬 Title:</strong> ${video.title}</li>
            <li class="list-group-item"><strong>🆔 Code:</strong> ${video.code}</li>
            <li class="list-group-item"><strong>📅 Date:</strong> ${new Date(video.created_at).toLocaleString()}</li>
          </ul>`
        : `<p class="text-muted">No video yet.</p>`;

      document.getElementById("video-count").textContent = data.totalVideo || '—';
      document.getElementById("genre-count").textContent = data.totalGenres || '—';
      document.getElementById("series-count").textContent = data.totalSeries || '—';

      document.getElementById('last-update').innerText =
        new Date().toLocaleTimeString();

    } catch (err) {
      console.error("❌ Dashboard load error:", err);
    }
  }

  setInterval(refreshDashboard, 15000);
  window.onload = refreshDashboard;
</script>

</body>
</html>
