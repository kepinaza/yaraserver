<!DOCTYPE html>
<html>
<head>
  <title>Upload Video</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
      font-size: 0.9rem;
    }

    #drop-zone {
      border: 2px dashed #0d6efd;
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
      color: #0d6efd;
      cursor: pointer;
      background-color: #fff;
      transition: background-color 0.3s ease;
    }

    #drop-zone.dragover {
      background-color: #e7f1ff;
    }

    #video-input {
      display: none;
    }

    #file-name {
      color: #555;
      min-height: 1rem;
      font-size: 0.85rem;
    }

    label {
      margin-bottom: 0.25rem;
      font-weight: 500;
    }

    input, button, video {
      font-size: 0.9rem;
    }

    .btn-sm {
      padding: 0.4rem 0.75rem;
      font-size: 0.85rem;
    }

    #stars {
      font-size: 1.4rem;
      user-select: none;
    }

    .star {
      cursor: pointer;
      color: #ccc;
      transition: color 0.2s;
    }

    .star:hover,
    .star.hovered {
      color: gold;
    }

    #genre-suggestions {
      z-index: 1000;
      max-height: 200px;
      overflow-y: auto;
    }

    video {
      max-width: 100%;
      height: auto;
    }

    @media (max-width: 576px) {
      
      body {
        padding: 1rem;
        font-size: 0.85rem;
      }

      h5 {
        font-size: 1.1rem;
      }

      label, input, button {
        font-size: 0.85rem;
      }

      #stars {
        font-size: 1.2rem;
      }

      .btn-sm {
        width: 100%;
        margin-bottom: 0.5rem;
      }

      .d-flex.justify-content-between {
        flex-direction: column;
        align-items: stretch;
      }
    }

@media (max-width: 768px) {
  body {
    padding: 1rem;
    font-size: 0.85rem;
  }

  h5 {
    font-size: 1.1rem;
    text-align: center;
  }

  #drop-zone {
    font-size: 0.85rem;
    padding: 1.25rem;
  }

  #file-name {
    font-size: 0.75rem;
    text-align: center;
  }

  .form-control-sm,
  .btn-sm {
    font-size: 0.8rem;
    padding: 0.5rem;
  }

  .form-check {
    margin-bottom: 1rem;
  }

  .btn-sm {
    width: 100%;
    margin-bottom: 0.5rem;
  }

  .d-flex.justify-content-between {
    flex-direction: column;
    gap: 0.5rem;
  }

  #upload-form {
    padding: 1rem;
  }

  #stars {
    font-size: 1.1rem;
  }

  .star {
    font-size: 1.3rem;
  }

  video {
    width: 100%;
    max-height: 240px;
  }

  #uploadModal {
    width: 90% !important;
    bottom: 1rem;
    right: 1rem;
    left: auto;
    padding: 1rem;
    font-size: 0.85rem;
  }
  .navbar {
    height: 56px;
    padding: 0.5rem 1rem;
    background-color: var(--bs-body-bg);
    z-index: 1050;
  }

  .navbar .navbar-toggler {
    padding: 0.25rem 0.5rem;
  }

  .navbar .navbar-brand {
    font-size: 1rem;
    flex-grow: 1;
    text-align: center;
    margin-left: 0.5rem;
  }

  .form-check-label,
  label {
    font-size: 0.85rem;
  }

  .position-relative {
    position: relative !important;
  }

  .list-group-item {
    font-size: 0.85rem;
    padding: 0.4rem 0.6rem;
  }
}
  

/* Dark mode styles for upload page */
body.dark-mode {
  background-color: #0b1e35;
  color: #e0e6ed;
}

body.dark-mode .navbar {
  background-color: #122b45;
  border-color: #2a4566;
  color: #e0e6ed;
}

body.dark-mode .navbar .navbar-brand,
body.dark-mode .navbar .btn,
body.dark-mode .navbar .navbar-toggler {
  color: #e0e6ed !important;
}

body.dark-mode .navbar-toggler {
  border-color: #ccc;
}

body.dark-mode .navbar-toggler:focus,
body.dark-mode .navbar-toggler:hover {
  background-color: #2d3e57;
}

body.dark-mode .navbar-toggler-icon {
  background-image: url("data:image/svg+xml;charset=utf8,%3Csvg viewBox='0 0 30 30' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath stroke='rgba(255,255,255,0.85)' stroke-width='2' stroke-linecap='round' stroke-miterlimit='10' d='M4 7h22M4 15h22M4 23h22'/%3E%3C/svg%3E");
}

body.dark-mode .bg-white,
body.dark-mode .shadow-sm,
body.dark-mode .shadow-lg,
body.dark-mode #upload-form,
body.dark-mode #drop-zone,
body.dark-mode #uploadModal {
  background-color: #152c48 !important;
  border-color: #2c4566 !important;
  color: #e0e6ed;
  box-shadow: none !important;
}

body.dark-mode .form-control,
body.dark-mode .form-control:focus,
body.dark-mode .form-check-input {
  background-color: #1e3a5a;
  color: #e0e6ed;
  border-color: #2c4566;
}

body.dark-mode .form-check-label,
body.dark-mode label {
  color: #ced7e3;
}

body.dark-mode .text-muted,
body.dark-mode .text-secondary {
  color: #aebcd1 !important;
}

body.dark-mode .btn-primary {
  background-color: #2b6cb0;
  border-color: #2b6cb0;
}

body.dark-mode .btn-outline-secondary {
  color: #9eb7d8;
  border-color: #9eb7d8;
}

body.dark-mode .btn-outline-secondary:hover {
  background-color: #9eb7d8;
  color: #000;
}

body.dark-mode .list-group-item {
  background-color: #1e3b60;
  color: #e0e6ed;
  border-color: #2c4566;
}

body.dark-mode .progress {
  background-color: #233a58;
}

body.dark-mode .progress-bar {
  background-color: #4da3ff;
}

body.dark-mode .star {
  color: #555;
}

body.dark-mode .star:hover,
body.dark-mode .star.hovered {
  color: gold;
}

body.dark-mode #drop-zone.dragover {
  background-color: #1b3659;
}

body > .container {
  margin-top: 4.5rem; /* Adjust based on your navbar height */
}

  </style>
</head>
<body class="container py-4 mt-5">
  <nav class="navbar border-bottom fixed-top px-3 d-flex justify-content-between align-items-center">
    <button class="navbar-toggler" type="button" id="sidebarToggle" aria-label="Toggle sidebar">
      <span class="navbar-toggler-icon"></span>
    </button>
    <span class="navbar-brand fw-semibold px-3 mb-0 ms-2">Video Library</span>
    <div class="ms-auto">
      <button id="toggleThemeBtn" class="btn btn-sm btn-outline-secondary">🌙 Dark Mode</button>
    </div>
  </nav>

  <form action="/video/edit/<%= video.id %>" method="POST" enctype="multipart/form-data" id="upload-form" class="bg-white border rounded p-3 shadow-sm">

    <!-- Dropzone -->
    <div id="drop-zone" class="mb-2">
        <div>
            <strong>📂 Replace Video (optional)</strong> a video here or <span class="text-decoration-underline">click to select</span>
            <small class="text-muted">Leave empty to keep existing video</small>
        </div>
    </div>

    <input type="file" id="video-input" name="video" accept="video/*">

    <!-- Title -->
    <div class="mb-2">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" class="form-control form-control-sm" value="<%= video.title %>" autocomplete="off" required>
    </div>

    <!-- Code -->
    <div class="mb-3">
      <label for="code" class="form-label">Code</label>
      <input type="text" name="code" id="code" class="form-control" value="<%= video.code %>" readonly>
    </div>

    <!-- Genre -->
    <div class="mb-2 position-relative">
      <label for="genre">Genre</label>
      <input type="text" id="genre" name="genre" value="<%= video.genre %>" class="form-control form-control-sm" autocomplete="off">
      <ul id="genre-suggestions" class="list-group position-absolute w-100 shadow-sm" style="display: none;"></ul>
    </div>

    <div class="form-check mb-2">
      <input class="form-check-input" type="checkbox" id="isSeries" <%= video.series_title ? 'checked' : ''%>>
      <label class="form-check-label" for="isSeries">Is this part of a series?</label>
    </div>

    <div id="series-fields" style="<%= video.series_title ? '' : 'display:none;' %>">
      <div class="mb-2">
        <label for="series_code">Series Code</label>
        <input type="text" id="series_code" name="series_code" value="<%= video.series_code || '' %>" class="form-control form-control-sm" autocomplete="off">
        <ul id="seriescode-suggestions" class="list-group position-absolute w-100 shadow-sm" style="display: none;"></ul>
      </div>

      <div class="mb-2">
        <label for="series_title">Series Title</label>
        <input type="text" id="series_title" name="series_title" value="<%= video.series_title || '' %>" class="form-control form-control-sm" autocomplete="off">
        <ul id="series-suggestions" class="list-group position-absolute w-100 shadow-sm" style="display: none;"></ul>
      </div>
    </div>

    <!-- Rating -->
    <div class="mb-3">
      <label for="rating">Rating</label>
      <div id="stars">
        <% for (let i = 1; i <= 5; i++) { %>
          <span class="star" data-value="<%= i %>" style="color:<%= i <= video.rating ? 'gold' : '#ccc' %>"><%= i <= video.rating ? '★' : '☆'%></span>
        <% } %>
      </div>
      <input type="hidden" name="rating" id="rating" value="<%= video.rating %>">
    </div>

    <!-- Preview -->
    <div class="mb-3">
      <label>Preview Current Video</label><br>
      <video id="preview" src="/<%= video.path %>" style="display: block;" controls></video>
    </div>

    <!-- Buttons -->
     <div class="d-flex justify-content-between gap-2">
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning btn-sm">
                Save Changes
            </button>

            <button type="button" class="btn btn-danger btn-sm" onclick="moveToDump(<%= video.id %>)">
                Delete
            </button>
        </div>

        <a href="/video" class="btn btn-outline-secondary btn-sm">
            Cancel
        </a>

     </div>
  </form>

  <!-- Upload Flyout Modal -->
  <div id="uploadModal" class="position-fixed bottom-0 end-0 m-3 bg-white border shadow-lg rounded p-3" style="width: 300px; display: none; z-index: 1050;">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <strong>Uploading...</strong>
      <button class="btn-close btn-sm" onclick="hideUploadModal()"></button>
    </div>
    <div id="uploadFileName" class="small mb-2 text-muted">video.mp4</div>
    <div class="progress mb-2" style="height: 8px;">
      <div id="uploadProgressBar" class="progress-bar" style="width: 0%;"></div>
    </div>
    <div id="uploadStatusText" class="small text-secondary">Starting upload...</div>
  </div>

  <script>
  function moveToDump(id) {
    if (!confirm("Delete this video will get the video to dump, you can still restore it later.")) return;

    fetch(`/video/dump/${id}`, {method: "POST" })
    .then(() => window.location.href = "/video")
    .catch(err => alert("Failed to delete video"));
  }  

  const themeBtn = document.getElementById('toggleThemeBtn');
  const body = document.body;

  // Load theme from localStorage
  if (localStorage.getItem('theme') === 'dark') {
    body.classList.add('dark-mode');
    themeBtn.textContent = '☀️ Light Mode';
  }

  themeBtn.addEventListener('click', () => {
    body.classList.toggle('dark-mode');
    const isDark = body.classList.contains('dark-mode');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    themeBtn.textContent = isDark ? '☀️ Light Mode' : '🌙 Dark Mode';
  });

  // On load, check localStorage
  window.addEventListener('DOMContentLoaded', () => {
    const darkMode = localStorage.getItem('darkMode') === 'true';
    setDarkMode(darkMode);
  });

    const stars = document.querySelectorAll('.star');
    const ratingInput = document.getElementById('rating');
    stars.forEach(star => {
      star.addEventListener('click', () => {
        const value = parseInt(star.dataset.value);
        ratingInput.value = value;
        stars.forEach(s => {
          s.innerHTML = s.dataset.value <= value ? '★' : '☆';
          s.style.color = s.dataset.value <= value ? 'gold' : '#ccc';
        });
      });
    });

    const dropZone = document.getElementById('drop-zone');
    const videoInput = document.getElementById('video-input');
    const preview = document.getElementById('preview');
    const fileNameDisplay = document.getElementById('file-name');

    dropZone.addEventListener('click', () => videoInput.click());

    dropZone.addEventListener('dragover', e => {
      e.preventDefault();
      dropZone.classList.add('dragover');
    });

    dropZone.addEventListener('dragleave', e => {
      e.preventDefault();
      dropZone.classList.remove('dragover');
    });

    dropZone.addEventListener('drop', e => {
      e.preventDefault();
      dropZone.classList.remove('dragover');
      if (e.dataTransfer.files.length) {
        const file = e.dataTransfer.files[0];
        if (file.type.startsWith('video/')) {
          videoInput.files = e.dataTransfer.files;
          showPreview(file);
          showFileName(file);
        } else {
          alert('Please drop a valid video file.');
        }
      }
    });

    videoInput.addEventListener('change', () => {
      if (videoInput.files.length) {
        const file = videoInput.files[0];
        showPreview(file);
        showFileName(file);
      }
    });

    function showPreview(file) {
      preview.src = URL.createObjectURL(file);
      preview.style.display = 'block';
    }

    function showFileName(file) {
      fileNameDisplay.textContent = `Selected: ${file.name}`;
    }

    // Genre autocomplete
    const genreInput = document.getElementById('genre');
    const suggestionBox = document.getElementById('genre-suggestions');

    genreInput.addEventListener('input', async () => {
      const raw = genreInput.value;
      const terms = raw.split(',').map(t => t.trim());
      const last = terms[terms.length - 1];

      if (!last) {
        suggestionBox.style.display = 'none';
        return;
      }

      try {
        const res = await fetch(`/api/genre?q=${encodeURIComponent(last)}`);
        const genres = await res.json();

        suggestionBox.innerHTML = '';
        if (genres.length) {
          genres.forEach(g => {
            const li = document.createElement('li');
            li.className = 'list-group-item list-group-item-action py-1 px-2';
            li.textContent = g.name;
            li.addEventListener('click', () => {
              terms[terms.length - 1] = g.name;
              genreInput.value = terms.join(', ') + ', ';
              suggestionBox.style.display = 'none';
            });
            suggestionBox.appendChild(li);
          });
          suggestionBox.style.display = 'block';
        } else {
          suggestionBox.style.display = 'none';
        }
      } catch (err) {
        console.error('Genre fetch error:', err);
        suggestionBox.style.display = 'none';
      }
    });

    document.addEventListener('click', (e) => {
      if (!genreInput.contains(e.target) && !suggestionBox.contains(e.target)) {
        suggestionBox.style.display = 'none';
      }
    });

    // Series autocomplete
    const seriesInput = document.getElementById('series_title');
    const seriesCodeInput = document.getElementById('series_code')
    const seriesSuggestionBox = document.getElementById('series-suggestions');
    const seriesCodeSuggestionBox = document.getElementById('seriescode-suggestions');
    
    seriesInput.addEventListener('input', async () => {
      const raw = seriesInput.value.trim();
      if (!raw) {
        seriesSuggestionBox.style.display = 'none';
        return;
      }

      try {
        const res = await fetch(`/api/series?q=${encodeURIComponent(raw)}`);
        const seriess = await res.json();

        seriesSuggestionBox.innerHTML = '';
        if(seriess.length) {
          seriess.forEach(s => {
            const li = document.createElement('li');
            li.className = 'list-group-item list-group-item-action py-1 px-2';
            li.textContent = s.series_title;
            li.addEventListener('click', () => {
              seriesInput.value = s.series_title;
              seriesCodeInput.value = s.series_code || '';
              seriesSuggestionBox.style.display = 'none';
            });
            seriesSuggestionBox.appendChild(li);
          });
          seriesSuggestionBox.style.display = 'block';
        } else {
          seriesSuggestionBox.style.display = 'none';
        }
      } catch (err) {
        console.error('Series fetch error:', err);
        seriesSuggestionBox.style.display = 'none';
      }
    });

    document.addEventListener('click', (e) => {
      if (!seriesInput.contains(e.target) && !seriesSuggestionBox.contains(e.target)) {
        seriesSuggestionBox.style.display = 'none';
      }
    });

    seriesCodeInput.addEventListener('input', async () => {
      const raw = seriesCodeInput.value.trim();
      if (!raw) {
        seriesCodeSuggestionBox.style.display = 'none';
        return;
      }

      try {
        const res = await fetch(`/api/series?q=${encodeURIComponent(raw)}`);
        const seriess = await res.json();

        seriesCodeSuggestionBox.innerHTML = '';
        if(seriess.length) {
          seriess.forEach(s => {
            const li = document.createElement('li');
            li.className = 'list-group-item list-group-item-action py-1 px-2';
            li.textContent = s.series_code;
            li.addEventListener('click', () => {
              seriesInput.value = s.series_title;
              seriesCodeInput.value = s.series_code || '';
              seriesCodeSuggestionBox.style.display = 'none';
            });
            seriesCodeSuggestionBox.appendChild(li);
          });
          seriesCodeSuggestionBox.style.display = 'block';
        } else {
          seriesCodeSuggestionBox.style.display = 'none';
        }
      } catch (err) {
        console.error('Series fetch error:', err);
        seriesCodeSuggestionBox.style.display = 'none';
      }
    });

    document.addEventListener('click', (e) => {
      if (!seriesCodeInput.contains(e.target) && !seriesCodeSuggestionBox.contains(e.target)) {
        seriesCodeSuggestionBox.style.display = 'none';
      }
    });

    const isSeries = document.getElementById('isSeries');
    const seriesFields = document.getElementById('series-fields');
    const codeInput = document.getElementById('code');

    isSeries.addEventListener('change', () => {
      seriesFields.style.display = isSeries.checked ? 'block' : 'none';
    });

  </script>
</body>
</html>
