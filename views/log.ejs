<!DOCTYPE html>
<html>
<head>
  <title>VIP Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-4">
  <h2 class="mt-5">📑 Log Aktivitas</h2>
  <table class="table table-bordered">
    <thead>
      <tr><th>#</th><th>Type</th><th>Username</th><th>Order ID</th><th>Log</th><th>Waktu</th></tr>
    </thead>
    <tbody>
      <% logs.forEach((log, i) => { %>
        <tr>
          <td><%= (logPage - 1) * 10 + i + 1 %></td>
          <td><%= log.type %></td>
          <td>@<%= log.username %></td>
          <td><%= log.order_id %></td>
          <td><%= log.message %></td>
          <td><%= new Date(log.log_time).toLocaleString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

    <!-- Pagination Logs -->
    <nav aria-label="Log pagination">
      <ul class="pagination">
        <% if (logPage > 1) { %>
          <li class="page-item">
            <a class="page-link" href="?logPage=<%= logPage - 1 %>">Prev</a>
          </li>
        <% } %>
        <li class="page-item disabled">
          <a class="page-link">Halaman <%= logPage %> dari <%= logTotalPages %></a>
        </li>
        <% if (logPage < logTotalPages) { %>
          <li class="page-item">
            <a class="page-link" href="?logPage=<%= logPage + 1 %>">Next</a>
          </li>
        <% } %>
      </ul>
    </nav>

</body>
</html>
