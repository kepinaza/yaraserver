<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Donation Logs</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { padding: 2rem; background-color: #f8f9fa; }
    .table td, .table th { vertical-align: middle; }
    .badge-verified { background-color: #28a745; }
    .badge-pending { background-color: #ffc107; color: #212529; }
  </style>
</head>
<body>
  <div class="container">
    <h3 class="mb-4">💰 Payment Logs</h3>
    <a href="/" class="btn btn-secondary mb-3">⬅ Back to Dashboard</a>

    <form method="get" class="row g-3 mb-4">
      <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Search by name or email" value="<%= search %>">
      </div>
      <div class="col-md-3">
        <select name="verified" class="form-select">
          <option value="">All Status</option>
          <option value="1" <%= verified === '1' ? 'selected' : '' %>>✅ Verified</option>
          <option value="0" <%= verified === '0' ? 'selected' : '' %>>⏳ Pending</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Search</button>
      </div>
    </form>

    <div class="table-responsive">
      <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Name</th>
            <th>Email</th>
            <th>Amount</th>
            <th>Message</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (payment.length > 0) { %>
            <% payment.forEach((pay, index) => { %>
              <tr>
                <td><%= (page - 1) * 10 + index + 1 %></td>
                <td><%= pay.donator_name %></td>
                <td><%= pay.donator_email %></td>
                <td>Rp <%= pay.amount_raw.toLocaleString() %></td>
                <td><%= pay.message || '-' %></td>
                <td>
                  <% if (pay.verified) { %>
                    <span class="badge badge-verified">✅ Verified</span>
                  <% } else { %>
                    <span class="badge badge-pending">⏳ Pending</span>
                  <% } %>
                </td>
                <td><%= new Date(pay.created_at).toLocaleString() %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center">No records found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
      <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center mt-3">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= page === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>&search=<%= search %>&verified=<%= verified %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  </div>
</body>
</html>
