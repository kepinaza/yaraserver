<!DOCTYPE html>
<html>
<head>
  <title>Dump</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container py-4">

<h4 class="mb-3">🗑 Dump (Trash)</h4>

<% if (!video.length) { %>
  <p class="text-muted">No deleted video.</p>
<% } %>

<div class="list-group">
  <% video.forEach(v => { %>
    <div class="list-group-item d-flex justify-content-between align-items-center">
      <div>
        <strong><%= v.title %></strong><br>
        <small class="text-muted"><%= v.path %></small>
      </div>

      <div class="d-flex gap-2">
        <form action="/video/restore/<%= v.id %>" method="POST">
          <button class="btn btn-sm btn-success">Restore</button>
        </form>

        <button
          class="btn btn-sm btn-danger"
          onclick="hardDelete(<%= v.id %>)"
        >
          Delete Permanently
        </button>
      </div>
    </div>
  <% }) %>
</div>

<script>
function hardDelete(id) {
  const password = prompt("Enter admin password to delete permanently:");
  if (!password) return;

  fetch(`/video/delete/${id}`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ password })
  })
  .then(res => {
    if (res.ok) location.reload();
    else alert("Wrong password or failed");
  });
}
</script>

</body>
</html>
