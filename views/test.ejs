<!DOCTYPE html>
<html>
<head>
  <title>Upload Video</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-4">
  <h2>📤 Upload Video</h2>
  <form action="/upload" method="POST" enctype="multipart/form-data" class="mb-4">
    <div class="mb-2">
      <label class="form-label">Video File</label>
      <input type="text" name="video" accept="video/*" class="form-control" required onchange="previewVideo(event)">
    </div>
    <div class="mb-2">
      <label class="form-label">Title</label>
      <input type="text" name="title" class="form-control" required>
    </div>
    <div class="mb-2">
      <label class="form-label">Code</label>
      <input type="text" name="code" class="form-control" required>
    </div>
    <div class="mb-2">
      <label class="form-label">Scheduled Date</label>
      <input type="datetime-local" name="scheduled_date" class="form-control" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Preview</label><br>
      <video id="preview" width="300" controls style="display:none;"></video>
    </div>
    <button type="submit" class="btn btn-primary">Upload</button>
  </form>

  <a href="/videos" class="btn btn-secondary">📼 View All Videos</a>

  <script>
    function previewVideo(event) {
      const file = event.target.files[0];
      const preview = document.getElementById('preview');
      preview.src = URL.createObjectURL(file);
      preview.style.display = 'block';
    }
  </script>
</body>
</html>
