<!DOCTYPE html>
<html>
<head>
  <title>Preview - <%= video.title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-4">
  <a href="/videos" class="btn btn-secondary mb-3">← Back</a>
  <h3><%= video.title %></h3>
  <p><strong>Code:</strong> <%= video.code %></p>
  <p><strong>Scheduled:</strong> <%= new Date(video.scheduled_date).toLocaleString() %></p>
  <p><strong>Status:</strong> <%= video.sent ? '✅ Sent' : '⏳ Scheduled' %></p>
  <video src="/<%= video.path %>" controls class="w-100 mt-3" style="max-height: 500px;"></video>
</body>
</html>
