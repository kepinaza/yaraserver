<!DOCTYPE html>
<html>
<head>
  <title>All Videos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <style>
    body {
      background-color: #f8f9fa;
      font-size: 0.95rem;
    }

    h2 {
      font-weight: 600;
      margin-bottom: 1.5rem;
    }

    .top-btns {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .video-card img {
      height: 160px;
      object-fit: cover;
    }

    .video-card {
      border-radius: 0.75rem;
      box-shadow: 0 0.25rem 0.75rem rgba(0, 0, 0, 0.05);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .video-card .card-body {
      padding: 1rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .video-card h5 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 0.4rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .video-meta {
      font-size: 0.78rem;
      color: #666;
      line-height: 1.3;
      margin-bottom: 0.3rem;
    }

    .upload-status {
      font-weight: 600;
      color: #28a745;
      font-size: 0.8rem;
      display: block;
      margin-top: 6px;
    }

    .upload-progress {
      height: 6px;
      margin-top: 6px;
    }

    .btn-sm {
      font-size: 0.8rem;
    }

    /* Responsive form row (scrollable on mobile) */
    form.row.row-cols-lg-auto {
      overflow-x: auto;
      flex-wrap: nowrap;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.5rem;
    }

    form.row.row-cols-lg-auto .col-12 {
      min-width: 150px;
    }

    @media (max-width: 576px) {
      .video-card img {
        height: 120px;
      }

      .video-card h5 {
        font-size: 0.9rem;
      }

      .video-meta {
        font-size: 0.75rem;
      }

      .modal-dialog {
        max-width: 90%;
      }
    }

    /* Add subtle transition for card hover */
    .video-card:hover {
      transform: translateY(-2px);
      transition: all 0.2s ease;
    }

    @media (max-width: 768px) {
      #videoPreviewModal .modal-dialog {
      margin: 1rem;
    }

    #videoPreviewModal .modal-content {
      border-radius: 1rem;
    }
  }
  </style>
</head>
<body class="p-4">
  <h2>📼 All Videos</h2>
  <div class="top-btns mb-4">
    <a href="/upload" class="btn btn-outline-secondary">⬅ Back to Upload</a>
    <a href="/" class="btn btn-primary">🏠 Dashboard</a>
  </div>

  <form method="GET" class="row row-cols-lg-auto g-2 align-items-center mb-4 flex-nowrap overflow-auto">
    <div class="col-12">
      <input type="text" name="search" class="form-control form-control-sm" placeholder="🔍 Title or Code" value="<%= query?.search || '' %>">
    </div>

    <div class="col-12">
      <select name="status" class="form-select form-select-sm">
        <option value="">All</option>
        <option value="scheduled" <%= query?.status === 'scheduled' ? 'selected' : '' %>>⏳ Scheduled</option>
        <option value="sent" <%= query?.status === 'sent' ? 'selected' : '' %>>✅ Sent</option>
      </select>
    </div>

    <div class="col-12">
      <select name="sort" class="form-select form-select-sm">
        <option value="newest" <%= query?.sort === 'newest' ? 'selected' : '' %>>🆕 Newest</option>
        <option value="oldest" <%= query?.sort === 'oldest' ? 'selected' : '' %>>📜 Oldest</option>
      </select>
    </div>

    <div class="col-12">
      <button type="submit" class="btn btn-sm btn-primary">Apply</button>
      <a href="/videos" class="btn btn-sm btn-secondary">Reset</a>
    </div>
  </form>

  <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 g-3">
    <% videos.forEach(v => { %>
      <div class="col">
        <div class="card video-card shadow-sm rounded h-100 border-0">
          <img src="/<%= v.thumbnail %>" class="card-img-top rounded-top" alt="Thumbnail" style="height: 160px; object-fit: cover;">
          <div class="card-body p-3 d-flex flex-column">
            <h5 class="card-title text-truncate mb-1" title="<%= v.title %>"><%= v.title %></h5>
          
            <div class="video-meta mb-1"><span class="badge bg-secondary">Code: <%= v.code %></span></div>
            <div class="video-meta mb-1">
              <span class="badge bg-info text-dark">📅 <%= new Date(v.scheduled_date).toLocaleString().replace('T', ' ').substring(0, 19) %></span>
            </div>
            <div class="video-meta mb-1 text-muted small">
              ⏱️ Countdown: <span class="countdown fw-semibold" data-date="<%= new Date(v.scheduled_date).toISOString() %>"></span>
            </div>
            <div class="video-meta mb-1">
              <span class="badge <%= v.sent ? 'bg-success' : 'bg-warning text-dark' %>">
                <%= v.sent ? '✅ Sent' : '⏳ Scheduled' %>
              </span>
            </div>
            <div class="video-meta mb-1 text-muted small">🎞️ Duration: 
              <% function formatDuration(seconds) {
                const m = Math.floor(seconds / 60);
                const s = Math.floor(seconds % 60);
                return m + ':' + (s < 10 ? '0' : '') + s;
              } %>
              <%= v.duration ? formatDuration(v.duration) : 'N/A' %>
            </div>
            <div class="video-meta mb-2 text-muted small">💾 Size: <%= v.size ? (v.size / (1024*1024)).toFixed(2) + ' MB' : 'N/A' %></div>
          
            <div class="mt-auto">
            <button 
              class="btn btn-outline-primary btn-sm w-100 mb-2 preview-btn"
              data-bs-toggle="modal"
              data-bs-target="#videoPreviewModal"
              data-title="<%= v.title %>"
              data-code="<%= v.code %>"
              data-date="<%= new Date(v.scheduled_date).toLocaleString() %>"
              data-iso-date="<%= new Date(v.scheduled_date).toISOString() %>"
              data-status="<%= v.sent ? '✅ Sent' : '⏳ Scheduled' %>"
              data-duration="<%= v.duration %>"
              data-size="<%= v.size %>"
              data-src="/<%= v.path %>">
              🔍 Preview
            </button>
              <form class="upload-now-form" data-video-id="<%= v.id %>">
                <button type="submit" class="btn btn-success btn-sm w-100">🚀 Upload Now</button>
                <progress class="upload-progress" value="0" max="100" style="width:100%; display:none; margin-top:4px;"></progress>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Video Preview Modal -->
  <div class="modal fade" id="videoPreviewModal" tabindex="-1" aria-labelledby="videoPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
      <div class="modal-content border-0 shadow rounded-3">
        <div class="modal-header bg-light border-bottom-0">
          <h6 class="modal-title" id="videoPreviewModalLabel">🎬 Video Preview</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-3">

          <h6 id="modalTitle" class="mb-2 fw-semibold text-primary"></h6>

          <ul class="list-unstyled small mb-3">
            <li><strong>🆔 Code:</strong> <span id="modalCode"></span></li>
            <li><strong>📅 Scheduled:</strong> <span id="modalDate"></span></li>
            <li><strong>📌 Status:</strong> <span id="modalStatus" class="badge bg-secondary"></span></li>
            <li><strong>⏱️ Countdown:</strong> <span id="modalCountdown" class="text-danger fw-semibold"></span></li>
            <li><strong>🎞️ Duration:</strong> <span id="modalDuration"></span></li>
            <li><strong>💾 Size:</strong> <span id="modalSize"></span></li>
          </ul>

          <div class="ratio ratio-16x9 rounded overflow-hidden border">
            <video id="modalVideo" class="w-100 h-100" controls></video>
          </div>
        </div>
      </div>
    </div>
  </div>


  <script>
    document.querySelectorAll('.preview-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const modal = document.getElementById('videoPreviewModal');
        modal.querySelector('#modalTitle').textContent = btn.dataset.title;
        modal.querySelector('#modalCode').textContent = btn.dataset.code;
        modal.querySelector('#modalDate').textContent = btn.dataset.date;
        modal.querySelector('#modalStatus').textContent = btn.dataset.status;
        modal.querySelector('#modalVideo').src = btn.dataset.src;
      });
    });

    document.querySelectorAll('.upload-now-form').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const videoId = form.dataset.videoId;
        const progressBar = form.querySelector('.upload-progress');

        // Create or find a status message span next to progress bar
        let statusMsg = form.querySelector('.upload-status');
        if (!statusMsg) {
          statusMsg = document.createElement('span');
          statusMsg.className = 'upload-status';
          statusMsg.style.marginLeft = '8px';
          form.appendChild(statusMsg);
        }

        statusMsg.textContent = '';   // clear previous
        progressBar.style.display = 'block';
        progressBar.value = 0;

        try {
          const response = await fetch(`/videos/upload/${videoId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({})
          });

          if (!response.ok) throw new Error('Upload failed');

          // Fake progress for demo - replace with real progress if available
          let val = 0;
          const interval = setInterval(() => {
            val += 10;
            progressBar.value = val;
            if (val >= 100) {
              clearInterval(interval);
              progressBar.style.display = 'none';
              statusMsg.textContent = 'Upload Done';
              // Optionally remove message after few seconds:
              // setTimeout(() => { statusMsg.textContent = ''; }, 3000);
            }
          }, 100);
        } catch (err) {
          progressBar.style.display = 'none';
          statusMsg.textContent = 'Upload Failed';
        }
      });
    });

    document.querySelectorAll('.preview-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const title = btn.dataset.title;
        const code = btn.dataset.code;
        const date = btn.dataset.date;
        const isoDate = btn.dataset.isoDate;
        const status = btn.dataset.status;
        const src = btn.dataset.src;
        const duration = btn.dataset.duration;
        const size = btn.dataset.size;
      
        document.getElementById('modalTitle').textContent = title;
        document.getElementById('modalCode').textContent = code;
        document.getElementById('modalDate').textContent = date;
        document.getElementById('modalStatus').textContent = status;
        document.getElementById('modalVideo').src = src;
      
        // Format duration
        const formattedDuration = duration ? formatDuration(duration) : 'N/A';
        document.getElementById('modalDuration').textContent = formattedDuration;
      
        // Format size
        const formattedSize = size ? (size / (1024 * 1024)).toFixed(2) + ' MB' : 'N/A';
        document.getElementById('modalSize').textContent = formattedSize;
      
        // Setup countdown
        const countdownSpan = document.getElementById('modalCountdown');
        updateCountdown(countdownSpan, new Date(isoDate));
      });
    });

    // Duration helper
    function formatDuration(seconds) {
      const m = Math.floor(seconds / 60);
      const s = Math.floor(seconds % 60);
      return `${m}:${s < 10 ? '0' : ''}${s}`;
    }

    // Countdown updater
    function updateCountdown(element, futureDate) {
      function update() {
        const now = new Date();
        const diff = futureDate - now;
        if (diff <= 0) {
          element.textContent = "Time reached";
          return;
        }
      
        const hours = Math.floor(diff / (1000 * 60 * 60));
        const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const secs = Math.floor((diff % (1000 * 60)) / 1000);
      
        element.textContent = `${hours}h ${mins}m ${secs}s`;
      }
    
      update();
      if (element._interval) clearInterval(element._interval);
      element._interval = setInterval(update, 1000);
    }

    function updateCountdowns() {
      const countdownElements = document.querySelectorAll('.countdown');
      const now = new Date();

      countdownElements.forEach(el => {
        const targetDate = new Date(el.dataset.date);
        const diff = targetDate - now;

        if (diff <= 0) {
          el.textContent = 'Time reached';
        } else {
          const hours = Math.floor(diff / (1000 * 60 * 60));
          const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((diff % (1000 * 60)) / 1000);

          el.textContent = `${hours}h ${minutes}m ${seconds}s`;
        }
      });
    }

    setInterval(updateCountdowns, 1000);
    updateCountdowns();
  </script>
</body>
</html>
