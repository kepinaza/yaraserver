<!DOCTYPE html>
<html>
<head>
  <title>VIP Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-4">
  <h2>🎖️ Daftar VIP Aktif</h2>
  <table class="table table-striped">
    <thead>
      <tr><th>#</th><th>Order ID</th><th>Telegram ID</th><th>Username</th><th>Join Date</th><th>Expired</th></tr>
    </thead>
    <tbody>
      <% vip.forEach((v, i) => { %>
        <tr>
          <td><%= (vipPage - 1) * 10 + i + 1 %></td>
          <td><%= v.order_id %></td>
          <td><%= v.telegram_id %></td>
          <td>@<%= v.username %></td>
          <td><%= v.join_date.toISOString().slice(0, 10) %></td>
          <td><%= v.expire_days %> hari</td>
        </tr>
      <% }) %>
    </tbody>
  </table>

    <!-- Pagination VIP -->
  <nav aria-label="VIP pagination">
    <ul class="pagination">
      <% if (vipPage > 1) { %>
        <li class="page-item">
          <a class="page-link" href="?vipPage=<%= vipPage - 1 %>">Prev</a>
        </li>
      <% } %>
      <li class="page-item disabled">
        <a class="page-link">Halaman <%= vipPage %> dari <%= vipTotalPages %></a>
      </li>
      <% if (vipPage < vipTotalPages) { %>
        <li class="page-item">
          <a class="page-link" href="?vipPage=<%= vipPage + 1 %>">Next</a>
        </li>
      <% } %>
    </ul>
  </nav>
</body>
</html>
